# Contact form uses formsubmit.co — no API key required.
# Submissions are sent to the email defined in src/data/content.js (contacts.email).
# First submission triggers a one-time confirmation email at that address; click the
# link inside to activate future deliveries. No sign-up needed.

# Optional Google reCAPTCHA v2 (checkbox). Leave empty to skip reCAPTCHA;
# the in-form "I am not a robot" checkbox + honeypot still run.
# Get a site key at https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=
